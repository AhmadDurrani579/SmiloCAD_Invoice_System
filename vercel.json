{
  "version": 2,
  "builds": [
    {
      "src": "backend/main.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    { 
      "source": "/api/(.*)", 
      "destination": "backend/main.py" 
    },
    { 
      "source": "/js/(.*)", 
      "destination": "backend/frontend/js/$1" 
    },
    { 
      "source": "/css/(.*)", 
      "destination": "backend/frontend/css/$1" 
    },
    { 
      "source": "/(.*)", 
      "destination": "backend/frontend/index.html" 
    }
  ]
}